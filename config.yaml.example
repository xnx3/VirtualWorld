# VirtualWorld Configuration
# Copy to data/config.yaml and modify as needed

# Language: "en" (English) or "zh" (Simplified Chinese / 简体中文)
language: "en"

# LLM Configuration (OpenAI-compatible API)
llm:
  # API base URL (supports any OpenAI-compatible endpoint)
  # Examples:
  #   OpenAI:    https://api.openai.com/v1
  #   Claude:    https://api.anthropic.com/v1
  #   Deepseek:  https://api.deepseek.com/v1
  #   Ollama:    http://localhost:11434/v1
  base_url: "http://localhost:11434/v1"
  api_key: ""  # Leave empty for local models
  model: "llama3"  # Model name
  max_tokens: 2048
  temperature: 0.8

# Network Configuration
network:
  listen_port: 19841          # TCP port for P2P connections
  discovery_port: 19840       # UDP port for LAN discovery
  bootstrap_nodes:            # Bootstrap server addresses for global node discovery
    - "http://45.205.24.48:8760"
  advertise_address: ""       # Optional public/LAN address announced on-chain; auto-detected when empty
  allow_local_bootstrap: false # Set true only when intentionally creating a brand-new civilization
  max_peers: 50               # Maximum peer connections
  discovery_interval: 30      # Seconds between LAN broadcasts
  sync_interval: 30           # Seconds between proactive chain sync attempts
  startup_sync_timeout: 45    # First-startup sync deadline before failing closed
  peer_endpoint_ttl: 600      # Seconds a published on-chain peer endpoint stays fresh
  relay_capable: false        # Set true only on publicly reachable nodes willing to relay traffic
  max_relay_hints: 3          # Max relay node IDs advertised in each on-chain contact card

# Simulation Configuration
simulation:
  tick_interval: 30           # Seconds between simulation ticks
  block_interval: 30          # Seconds between blocks
  min_beings: 10              # Minimum beings in the world
  max_npc_per_node: 5         # Maximum NPCs this node will simulate

# Blockchain Configuration
chain:
  contribution_vote_window: 5      # Blocks to wait for votes
  contribution_min_voters: 0.51    # Minimum voter participation (51%)
  proposal_rate_limit: 10          # Max 1 proposal per N ticks while an older proposal is still pending
  priest_grace_period: 50          # Ticks without priest before reset
  creator_succession_threshold: 1000  # Min beings for succession

# Being Configuration
being:
  initial_lifespan: 1000      # Ticks for initial lifespan
  hibernate_safety_timeout: 30 # Seconds to find safe location before forced hibernate
